# AgentPower local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Future PostgreSQL adapter
DATABASE_URL=postgres://user:password@localhost:5432/agentpower

# Future Redis/BullMQ adapter
REDIS_URL=redis://localhost:6379

# Future GitHub App adapter
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Optional platform-owned Stripe account for hosted deployments.
# Individual projects can connect their own keys through the Payment Gateways UI.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
